# Copy this file to .env and adjust as needed.
# FlightRisk does not require any paid services or API keys for v1 --
# these variables are optional configuration knobs.

# Probability threshold (0.0-1.0) used to convert delay_probability into a
# binary risk decision inside the API/model. Risk-level buckets (low/
# moderate/high) are independent of this and are fixed in src/config.py.
FLIGHTRISK_THRESHOLD=0.5

# Port the FastAPI service listens on inside the container (docker-compose
# maps this to the host). Uvicorn's --port flag takes precedence when
# running locally without Docker.
API_PORT=8000

# Port the Streamlit dashboard listens on inside the container.
STREAMLIT_PORT=8501

# Base URL the Streamlit dashboard/other clients could use to reach the API
# if you split the dashboard into a separate process that calls the API
# over HTTP instead of importing the prediction service directly.
FLIGHTRISK_API_URL=http://localhost:8000

# Optional runtime path overrides used by containers and managed platforms.
FLIGHTRISK_MODEL_PATH=models/flightrisk_model.joblib
FLIGHTRISK_SCHEDULE_CONTEXT_PATH=data/processed/schedule_context.joblib
FLIGHTRISK_PREDICTION_LOG_PATH=monitoring/predictions.jsonl
